# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  QMC Quantum Framework v2.7.1 — Exemple de configuration                  ║
# ║  Copiez ce fichier en `.env` puis remplacez les valeurs d'exemple.        ║
# ║  ⚠️ Ne commitez JAMAIS votre .env (il est ignoré par .gitignore).         ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ============================================================================
# COMPTES IBM QUANTUM (multi-comptes)
# ----------------------------------------------------------------------------
# Un compte = une variable IBM_API_KEY_<LABEL> (le LABEL est libre : nom, alias…).
# Optionnellement, ajoutez IBM_INSTANCE_<LABEL> = CRN de l'instance (plan payant).
# Le framework détecte automatiquement TOUS les comptes définis ici.
# ============================================================================

IBM_API_KEY_ALICE=your_ibm_api_key_here_alice
IBM_API_KEY_BOB=your_ibm_api_key_here_bob

# Exemple de compte AVEC instance CRN dédiée :
IBM_API_KEY_LAB=your_ibm_api_key_here_lab
IBM_INSTANCE_LAB=crn:v1:bluemix:public:quantum-computing:us-east:a/xxxxxxxx::

# ----------------------------------------------------------------------------
# COMPTE ACTIF (par défaut) — IBM_API_KEY_ACTIVE_<LABEL>
# C'est le compte utilisé si vous ne précisez pas `account=` à la connexion.
# ----------------------------------------------------------------------------
IBM_API_KEY_ACTIVE_QMCLAB=your_active_ibm_api_key_here
IBM_INSTANCE_QMCLAB=crn:v1:bluemix:public:quantum-computing:us-east:a/xxxxxxxx::

# ============================================================================
# GÉNÉRATION DE RAPPORTS / ARCHIVES
# ============================================================================

# Génère un rapport HTML après chaque exécution QPU (défaut: true). Désactiver = risque de perdre des infos précieuses!
QMC_GENERATE_REPORT=true

# Génère une archive JSON après chaque exécution QPU (défaut: true). Désactiver = perte des données brutes!
QMC_GENERATE_ARCHIVE=true

# Skip la confirmation avant envoi au QPU (défaut: false). DANGEREUX! true = jobs envoyés sans demander = risque gaspillage crédits. Utile uniquement pour scripts automatisés/batch
QMC_AUTO_CONFIRM=false

# Skip la récupération automatique de l'état QPU avant run (défaut: false), TRÈS DÉCONSEILLÉ! true = données calibration FACTICES dans rapports. Utile uniquement pour tests rapides
QMC_SKIP_QPU_STATE_FETCH=false

# ============================================================================
# QMC ARCHIVE MANAGER (cloud, optionnel)
# ⚠️ v2.7.1 : l'URL DOIT être en https et l'hôte autorisé (allowlist anti-exfiltration).
# ============================================================================

# URL de l'API QMC Archive Manager
QMC_ARCHIVE_URL=https://votre-projet.supabase.co/functions/v1/upload

# Token d'authentification API (REQUIS pour activer l'upload). Obtenez-le depuis: QMC Archive Manager → Profil → API Tokens. Sans token = upload désactivé silencieusement
QMC_ARCHIVE_TOKEN=qmc_your_archive_token_here

# Projets par défaut pour l'upload (UUIDs séparés par virgules). Utilisés si archive_projects n'est pas spécifié dans run_on_qpu(). Laissez vide pour ne pas assigner de projet par défaut
QMC_ARCHIVE_DEFAULT_PROJECTS=

# Active/désactive l'upload vers QMC Archive (défaut: true). false = désactive explicitement même si token présent
QMC_ARCHIVE_UPLOAD=true

# Hôtes additionnels autorisés pour l'upload (séparés par des virgules), en plus de *.supabase.co
# QMC_ARCHIVE_ALLOWED_HOSTS=archive.example.com

# ============================================================================
# MONITORING & DÉPENDANCES
# ============================================================================

# Active le monitoring robuste avec timeout et reconnexion auto (défaut: true). false = monitoring basique sans récupération d'erreurs
QMC_ROBUST_MONITORING=true

# Désactive la vérification des dépendances au chargement (défaut: false). true = le framework démarre sans vérifier les packages
QMC_SKIP_DEP_CHECK=false

# Installe automatiquement les packages manquants sans demander (défaut: false). [v2.7.1] L'import reste PUR : true = autorise l'auto-install à l'import
QMC_AUTO_INSTALL_DEPS=false

# Mode silencieux pour la vérification des dépendances (défaut: false). true = pas de banner ni de messages sauf erreurs
QMC_SILENT_DEP_CHECK=false

# [v2.7.1] Autorise pip --break-system-packages sur environnement géré PEP 668 (défaut: false, RISQUÉ). Préférez un venv.
QMC_PIP_BREAK_SYSTEM_PACKAGES=false

# Chargement lazy des builders de circuits (défaut: false). true = builders chargés uniquement quand utilisés (démarrage plus rapide)
QMC_LAZY_REGISTER=false
